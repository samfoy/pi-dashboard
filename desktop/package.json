{
  "name": "pi-dashboard-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.pi.dashboard",
    "productName": "Pi Dashboard",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.icns",
      "target": ["dmg", "dir"]
    },
    "files": [
      "main.js",
      "preload.js",
      "tunnel.js",
      "overlay.html",
      "icon.png"
    ]
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
